// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid()) // use cuid to generate a "Collision-resistant" unique id
  username       String
  email          String   @unique //each user should have a unique email
  password       String
  profilePicture String   @default("assets/PFP_Blank.jpg")
  bio            String   @default("")
  date           DateTime @default(now())

  posts        Post[] // FK to post table
  comments     Comment[] // FK to comment table
  // since we cant put user directly into itself as FK we made another table to capture interactions
  following    Follow[]      @relation("Following") //connects back to the other table
  followers    Follow[]      @relation("Followers")
  // for these two its similar to following & followers
  postLikes    PostLike[]
  commentLikes CommentLike[]
}

model Follow {
  id String @id @default(cuid())

  followerId  String
  followingId String

  follower  User @relation("Following", fields: [followerId], references: [id])
  following User @relation("Followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId]) //each user can only follow, or be followed by, someone else once
}

model Post {
  id      String   @id @default(cuid())
  content String
  date    DateTime @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  comments Comment[]
  likes    PostLike[]
}

model PostLike {
  id String @id @default(cuid())

  userId String
  postId String

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId]) // each user can be related to the same post once
}

model Comment {
  id      String   @id @default(cuid())
  content String
  date    DateTime @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  postId String
  post   Post   @relation(fields: [postId], references: [id])

  likes CommentLike[]
}

model CommentLike {
  id String @id @default(cuid())

  userId    String
  commentId String

  user    User    @relation(fields: [userId], references: [id])
  comment Comment @relation(fields: [commentId], references: [id])

  @@unique([userId, commentId]) // each user can be related to the same comment once
}
